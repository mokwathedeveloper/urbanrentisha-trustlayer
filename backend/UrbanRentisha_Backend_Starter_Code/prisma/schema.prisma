generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  TENANT
  LANDLORD
  AGENT
  MANAGER
  ADMIN
  PLATFORM
}

enum VerificationStage {
  PROFILE_CREATED
  DOCUMENTS_UPLOADED
  UNDER_REVIEW
  NEEDS_CORRECTION
  APPROVED
  REJECTED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CORRECTION
}

enum DocumentType {
  ID_CARD
  GOOD_CONDUCT
  PERSONAL_DOCUMENT
  ASSET_DOCUMENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ListingAvailability {
  AVAILABLE
  RESERVED
  RENTED
}

enum ViewingRequestStatus {
  CREATED
  QUEUED
  AWAITING_PAYMENT
  PAYMENT_RECEIVED
  PROOF_GENERATING
  PROOF_READY
  PROOF_VERIFIED
  ACCESS_UNLOCKED
  EXPIRED
  REVOKED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  AWAITING_PAYMENT
  RECEIVED
  RELEASED
  FAILED
  REFUNDED
  EXPIRED
}

enum ProofStatus {
  NOT_STARTED
  GENERATING
  GENERATED
  SUBMITTED
  VERIFIED
  FAILED
}

enum ViewingCodeStatus {
  LOCKED
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  ESCALATED
}

enum ReportType {
  FAKE_LISTING
  UNSAFE_PAYMENT
  AGENT_MISMATCH
  WRONG_PROPERTY
  SUSPICIOUS_BEHAVIOR
  OTHER
}

enum NotificationType {
  PAYMENT
  PROOF
  VIEWING_CODE
  REPORT
  SYSTEM
}

enum AuditSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  phone              String?
  avatarUrl          String?
  role               UserRole
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(false)
  walletAddress      String?
  lastActiveAt       DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tenantProfile     TenantProfile?
  landlordProfile   LandlordProfile?
  agentProfile      AgentProfile?
  managerProfile    ManagerProfile?
  listings          Listing[]        @relation("ListingOwner")
  reports           Report[]         @relation("ReportReporter")
  reportsResponded  Report[]         @relation("ReportResponder")
  notifications     Notification[]
  auditLogs         AuditLog[]       @relation("AuditActor")
  savedListings     SavedListing[]
  messages          Message[]
  documents         Document[]       @relation("DocumentUploader")
  reviewedDocuments Document[]       @relation("DocumentReviewer")
  listingThreads    ListingThread[]
  reviewsReceived   Review[]         @relation("ReviewTarget")
  reviewsWritten    Review[]         @relation("ReviewAuthor")
  supportThreadsAsUser  SupportThread[] @relation("SupportThreadUser")
  supportThreadsAsAdmin SupportThread[] @relation("SupportThreadAdmin")
}

model TenantProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustScore        Int               @default(70)
  verificationStage VerificationStage @default(PROFILE_CREATED)
  verifiedBadge     Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  viewingRequests ViewingRequest[]
  documents       Document[]
}

model LandlordProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName       String?
  verificationStage VerificationStage @default(PROFILE_CREATED)
  trustScore        Int               @default(70)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  agents    AgentProfile[]
  managers  ManagerProfile[]
  documents Document[]
}

model AgentProfile {
  id                      String            @id @default(cuid())
  userId                  String            @unique
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyName              String?
  licenseNumber           String?
  verificationStatus      String            @default("pending")
  verificationStage       VerificationStage @default(PROFILE_CREATED)
  trustScore              Int               @default(70)
  reportCount             Int               @default(0)
  landlordId              String?
  landlord                LandlordProfile?  @relation(fields: [landlordId], references: [id])
  activationCodeHash      String?
  activationCodeExpiresAt DateTime?
  activatedAt             DateTime?
  attestationTxHash       String?
  attestedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  listings  Listing[]
  documents Document[]
}

model ManagerProfile {
  id                      String            @id @default(cuid())
  userId                  String            @unique
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyName              String?
  licenseNumber           String?
  verificationStatus      String            @default("pending")
  verificationStage       VerificationStage @default(PROFILE_CREATED)
  trustScore              Int               @default(70)
  reportCount             Int               @default(0)
  landlordId              String?
  landlord                LandlordProfile?  @relation(fields: [landlordId], references: [id])
  activationCodeHash      String?
  activationCodeExpiresAt DateTime?
  activatedAt             DateTime?
  attestationTxHash       String?
  attestedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  listings  Listing[]
  documents Document[]
}

model Document {
  id                String           @id @default(cuid())
  uploaderId        String
  uploader          User             @relation("DocumentUploader", fields: [uploaderId], references: [id])
  tenantProfileId   String?
  tenantProfile     TenantProfile?   @relation(fields: [tenantProfileId], references: [id])
  landlordProfileId String?
  landlordProfile   LandlordProfile? @relation(fields: [landlordProfileId], references: [id])
  agentProfileId    String?
  agentProfile      AgentProfile?    @relation(fields: [agentProfileId], references: [id])
  managerProfileId  String?
  managerProfile    ManagerProfile?  @relation(fields: [managerProfileId], references: [id])
  fileUrl           String
  fileName          String
  documentType      DocumentType?
  status            DocumentStatus   @default(PENDING)
  reviewNote        String?
  reviewedById      String?
  reviewedBy        User?            @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Listing {
  id                   String              @id @default(cuid())
  externalListingId    String?
  title                String
  description          String
  location             String
  address              String?
  rentAmount           Int
  currency             String              @default("KES")
  viewingFee           Int
  bedrooms             Int?
  bathrooms            Int?
  propertyType         String
  imageUrl             String?
  verificationStatus   ListingStatus       @default(PENDING_REVIEW)
  availabilityStatus   ListingAvailability @default(AVAILABLE)
  reservedByRequestId  String?             @unique
  reservedByRequest    ViewingRequest?     @relation("ListingReservation", fields: [reservedByRequestId], references: [id])
  reservationExpiresAt DateTime?
  ownerId              String
  owner                User                @relation("ListingOwner", fields: [ownerId], references: [id])
  agentId              String?
  agent                AgentProfile?       @relation(fields: [agentId], references: [id])
  managerId            String?
  manager              ManagerProfile?     @relation(fields: [managerId], references: [id])
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  viewingRequests ViewingRequest[] @relation("ListingRequests")
  reports         Report[]
  savedBy         SavedListing[]
  images          ListingImage[]
  notifications   Notification[]
  threads         ListingThread[]
  reviews         Review[]
}

model ListingImage {
  id         String    @id @default(cuid())
  listingId  String
  listing    Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url        String
  order      Int
  latitude   Float?
  longitude  Float?
  capturedAt DateTime?
  device     String?
  gpsPresent Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model ViewingRequest {
  id            String               @id @default(cuid())
  listingId     String
  listing       Listing              @relation("ListingRequests", fields: [listingId], references: [id])
  tenantId      String
  tenant        TenantProfile        @relation(fields: [tenantId], references: [id])
  preferredDate DateTime?
  preferredTime String?
  status        ViewingRequestStatus @default(CREATED)
  turnExpiresAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  payment           Payment?
  zkProof           ZkProof?
  proofVerification ProofVerification?
  viewingCode       ViewingCode?
  reports           Report[]
  notifications     Notification[]
  messages          Message[]
  reservedListing   Listing?           @relation("ListingReservation")
}

model Message {
  id               String          @id @default(cuid())
  viewingRequestId String?
  viewingRequest   ViewingRequest? @relation(fields: [viewingRequestId], references: [id], onDelete: Cascade)
  listingThreadId  String?
  listingThread    ListingThread?  @relation(fields: [listingThreadId], references: [id], onDelete: Cascade)
  supportThreadId  String?
  supportThread    SupportThread?  @relation(fields: [supportThreadId], references: [id], onDelete: Cascade)
  senderId         String
  sender           User            @relation(fields: [senderId], references: [id])
  body             String
  readAt           DateTime?
  createdAt        DateTime        @default(now())
}

model ListingThread {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  messages Message[]

  @@unique([listingId, tenantId])
}

/// One thread per user with the platform's human support team. Any
/// ADMIN/PLATFORM user can see and reply to any open thread; the first
/// admin to reply "claims" it via assignedAdminId, mirroring how a real
/// support inbox assigns tickets without requiring upfront routing rules.
model SupportThread {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("SupportThreadUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdminId String?
  assignedAdmin   User?    @relation("SupportThreadAdmin", fields: [assignedAdminId], references: [id])
  status          String   @default("OPEN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages Message[]

  @@unique([userId])
}

model Review {
  id           String   @id @default(cuid())
  targetUserId String
  targetUser   User     @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User     @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  rating       Int
  comment      String?
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([reviewerId, targetUserId])
}

model Payment {
  id                  String         @id @default(cuid())
  viewingRequestId    String         @unique
  viewingRequest      ViewingRequest @relation(fields: [viewingRequestId], references: [id])
  amount              Int
  currency            String         @default("KES")
  stellarAsset        String         @default("XLM_TEST")
  destinationWallet   String
  payerWallet         String?
  stellarMemo         String
  txHash              String?
  status              PaymentStatus  @default(CREATED)
  paidAt              DateTime?
  escrowDepositTxHash String?
  escrowReleaseTxHash String?
  escrowReleasedAt    DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model ZkProof {
  id               String         @id @default(cuid())
  viewingRequestId String         @unique
  viewingRequest   ViewingRequest @relation(fields: [viewingRequestId], references: [id])
  proofHash        String?
  publicInputs     Json?
  privateHintHash  String?
  status           ProofStatus    @default(NOT_STARTED)
  generatedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ProofVerification {
  id               String         @id @default(cuid())
  viewingRequestId String         @unique
  viewingRequest   ViewingRequest @relation(fields: [viewingRequestId], references: [id])
  proofId          String?
  sorobanTxHash    String?
  verifierAddress  String?
  status           ProofStatus    @default(SUBMITTED)
  verifiedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ViewingCode {
  id               String            @id @default(cuid())
  viewingRequestId String            @unique
  viewingRequest   ViewingRequest    @relation(fields: [viewingRequestId], references: [id])
  code             String            @unique
  status           ViewingCodeStatus @default(LOCKED)
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Report {
  id               String          @id @default(cuid())
  listingId        String?
  listing          Listing?        @relation(fields: [listingId], references: [id])
  viewingRequestId String?
  viewingRequest   ViewingRequest? @relation(fields: [viewingRequestId], references: [id])
  reporterId       String
  reporter         User            @relation("ReportReporter", fields: [reporterId], references: [id])
  reportType       ReportType
  description      String
  status           ReportStatus    @default(OPEN)
  severity         String          @default("medium")
  allowContact     Boolean         @default(false)
  firstRespondedAt DateTime?
  respondedById    String?
  respondedBy      User?           @relation("ReportResponder", fields: [respondedById], references: [id])
  responseNote     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Notification {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  type             NotificationType
  title            String
  message          String
  viewingRequestId String?
  viewingRequest   ViewingRequest?  @relation(fields: [viewingRequestId], references: [id])
  listingId        String?
  listing          Listing?         @relation(fields: [listingId], references: [id])
  readAt           DateTime?
  createdAt        DateTime         @default(now())
}

model AuditLog {
  id         String        @id @default(cuid())
  actorId    String?
  actor      User?         @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  severity   AuditSeverity @default(INFO)
  metadata   Json?
  createdAt  DateTime      @default(now())
}

model ApiClient {
  id            String   @id @default(cuid())
  name          String
  apiKeyHash    String
  status        String   @default("active")
  allowedOrigin String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  webhookEvents WebhookEvent[]
}

model WebhookEvent {
  id          String    @id @default(cuid())
  apiClientId String
  apiClient   ApiClient @relation(fields: [apiClientId], references: [id])
  event       String
  targetUrl   String
  secretHash  String
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
