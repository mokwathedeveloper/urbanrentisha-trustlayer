# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# Auth
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# Stellar testnet
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_PLATFORM_PUBLIC_KEY="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STELLAR_PLATFORM_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ZK proof service
ZK_MODE="mock"
ZK_PROVER_URL="http://localhost:5001"
ZK_PROOF_SALT="replace-with-proof-salt"

# Webhooks
WEBHOOK_SIGNING_SECRET="replace-with-webhook-secret"

# Admin bootstrap
ADMIN_EMAIL="admin@urbanrentisha.local"
ADMIN_PASSWORD="ChangeMe123!"
