# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?pgbouncer=true&connect_timeout=30&connection_limit=20&pool_timeout=20"
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# Auth
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# Stellar testnet
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_PLATFORM_PUBLIC_KEY="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STELLAR_PLATFORM_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Demo-only testnet treasury, funded via Friendbot. Stands in for a tenant's
# payment source so "Pay Viewing Fee" needs zero wallet/crypto knowledge -
# not a production payment method, see StellarService.payFromTreasury.
STELLAR_DEMO_TREASURY_PUBLIC_KEY="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STELLAR_DEMO_TREASURY_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ZK proof service
ZK_PROOF_SALT="replace-with-proof-salt"

# Soroban verifier contract (UrbanRentishaTrustVerifier, see contracts/trust-verifier/)
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
TRUST_VERIFIER_CONTRACT_ID="CAO2EEH75TIJWGQEMKIO2RLDPWHQJ7HLDTG7HVYYGS6ZEV62HZQYDGSW"

# Soroban escrow contract (UrbanRentishaEscrow, see contracts/escrow/)
ESCROW_CONTRACT_ID="CCDYGIL6TW3CDBYUOOZFEY7LJXCY35AFTS3FGIMIG37PYMKAAJW5ESTY"
NATIVE_ASSET_CONTRACT_ID="CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC"

# Webhooks
WEBHOOK_SIGNING_SECRET="replace-with-webhook-secret"

# Reconciliation cron trigger (required in production - see
# src/reconciliation/reconciliation.controller.ts). Vercel Cron
# automatically sends this as `Authorization: Bearer <value>` when the
# env var is literally named CRON_SECRET.
CRON_SECRET="replace-with-a-long-random-cron-secret"

# Admin bootstrap
ADMIN_EMAIL="admin@urbanrentisha.local"
ADMIN_PASSWORD="ChangeMe123!"

# Supabase Storage (server-only — never expose the service-role key to the frontend)
SUPABASE_URL="https://project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
