# Copy to .env.e2e (gitignored) and fill in real values, or export these
# directly in your shell before running the E2E test scripts. Never commit
# real passwords - see README's "Running the E2E tests" section.

# Where the frontend and backend are running. Defaults to local dev servers
# if unset (see playwright.config.ts / e2e/env.ts).
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000/api/v1

# Demo tenant account - see DEMO_GUIDE.md for the currently confirmed-working value.
TEST_TENANT_EMAIL=
TEST_TENANT_PASSWORD=

# Demo "landlord/owner" account. This app has no confirmed-working LANDLORD
# demo account today - point this at the AGENT demo account
# (agent@urbanrentisha.local, see DEMO_GUIDE.md) unless you have a real one.
TEST_LANDLORD_EMAIL=
TEST_LANDLORD_PASSWORD=

# Demo admin account - see DEMO_GUIDE.md for the currently confirmed-working value.
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Set to "true" only to run the tests that create real data (a viewing
# request, a review). Off by default - see README's safety notes before
# enabling this, especially if APP_BASE_URL/API_BASE_URL point at an
# environment sharing a database with production.
E2E_ALLOW_MUTATIONS=false
